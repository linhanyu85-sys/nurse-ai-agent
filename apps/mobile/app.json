{
  "expo": {
    "name": "护理AI助手",
    "slug": "ai-nursing-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/brand-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f6f8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.linhanyu.ainursing"
    },
    "android": {
      "package": "com.linhanyu.ainursing",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand-logo.png",
        "backgroundColor": "#f4f6f8"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "允许访问麦克风，用于语音录入。"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "64e6e0c0-929b-498b-880b-cd1b1410dc05"
      }
    },
    "owner": "linmeili"
  }
}
